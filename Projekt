import tkinter as tk
import random

root = tk.Tk()
root.title("Hádanie čísla")
root.geometry("300x400")

cislo = random.randint(1, 100)

label = tk.Label(root, text="Hádaj číslo od 1 do 100:")
label.pack(pady=20)

vstup = tk.Entry(root)
vstup.pack(pady=10)

vysledok = tk.Label(root, text="")
vysledok.pack(pady=10)

def hra():
    try:
        zadane = int(vstup.get())
        if zadane < cislo:
            vysledok.config(text="Vyššie!")
        elif zadane > cislo:
            vysledok.config(text="Nižšie!")
        else:
            vysledok.config(text="Správne! Číslo bolo " + str(cislo))
    except:
        vysledok.config(text="Zadaj číslo!")

tlacitko = tk.Button(root, text="Hádaj", command=hra)
tlacitko.pack(pady=10)

root.mainloop()
